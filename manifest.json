{
    "manifest_version": 3,
    "name": "Raindrop Menu",
    "version": "1.0",
    "description": "Browse your Raindrop.io collections as a classic bookmark menu",
    "permissions": ["storage", "tabs"],
    "host_permissions": [
        "https://api.raindrop.io/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
